# Maintainer: MurderFromMars <untamedprodigy67@gmail.com>

pkgname=cyberxero-toolkit
pkgver=0.1.6
pkgrel=3
pkgdesc="GTK4 GUI to manage CyberXero Toolkit tools and settings on Arch-based Linux"
arch=('x86_64')
url="https://github.com/MurderFromMars/CyberXero-Toolkit"
license=('GPL-3.0-or-later')
depends=(
    'gtk4'
    'glib2'
    'libadwaita'
    'vte4'
    'flatpak'
    'scx-tools'
    'scx-scheds'
    'polkit')
optdepends=(
    'scxctl: optional CLI for scx_loader (toolkit uses the D-Bus API directly)')
makedepends=(
    'rust'
    'cargo'
    'pkgconf')
provides=('cyberxero-toolkit')
conflicts=('cyberxero-toolkit' 'xero-toolkit')
replaces=('xero-toolkit' 'xlapit-cli')
options=('!emptydirs')

build() {
  cd "${startdir}/.."

  # CachyOS-style v3 optimizations are pinned in Cargo.toml's [profile.release]
  # and .cargo/config.toml's rustflags — applies automatically.
  cargo build --release --locked
}

package() {
  cd "${startdir}/.."

  # Install binaries into /opt/cyberxero-toolkit
  install -d "${pkgdir}/opt/cyberxero-toolkit"
  install -Dm755 "target/release/cyberxero-toolkit" \
    "${pkgdir}/opt/cyberxero-toolkit/cyberxero-toolkit"
  install -Dm755 "target/release/cyberxero-authd" \
    "${pkgdir}/opt/cyberxero-toolkit/cyberxero-authd"
  install -Dm755 "target/release/cyberxero-auth" \
    "${pkgdir}/opt/cyberxero-toolkit/cyberxero-auth"

  # Install sources (helper scripts)
  install -d "${pkgdir}/opt/cyberxero-toolkit/sources/scripts"
  install -m755 sources/scripts/* "${pkgdir}/opt/cyberxero-toolkit/sources/scripts/"

  # Convenience symlink in /usr/bin
  install -d "${pkgdir}/usr/bin"
  ln -s "/opt/cyberxero-toolkit/cyberxero-toolkit" "${pkgdir}/usr/bin/cyberxero-toolkit"

  # Install desktop file
  install -Dm644 "packaging/cyberxero-toolkit.desktop" \
    "${pkgdir}/usr/share/applications/cyberxero-toolkit.desktop"

  # Install icon
  install -Dm644 "gui/resources/icons/scalable/apps/cyberxero-toolkit.png" \
    "${pkgdir}/usr/share/icons/hicolor/scalable/apps/cyberxero-toolkit.png"

  # Install license
  install -Dm644 "LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}

post_install() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
}

post_upgrade() {
  post_install
}

post_remove() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
}
